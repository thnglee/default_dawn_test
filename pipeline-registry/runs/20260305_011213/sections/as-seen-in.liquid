{%- comment -%}
  Section: as-seen-in
  Type: image_banner
  Generated by: Section Conversion Agent v1.2
  Dawn version: 15.0
{%- endcomment -%}

{%- comment -%}
  UNRESOLVED: The provided HTML snippet depicts a product image area, not the "As Seen In" logo bar.
  FALLBACK APPLIED: Section rebuilt entirely from content_signals (heading, publication logos, dark background bar).
  REASON: HTML snippet does not match the described section type or content signals.
{%- endcomment -%}

<section
  class="section-{{ section.id }} as-seen-in color-{{ section.settings.color_scheme }} gradient"
>
  <div class="as-seen-in__inner page-width">
    {%- if section.settings.heading != blank -%}
      <{{ section.settings.heading_tag }} class="as-seen-in__heading {{ section.settings.heading_size }}">
        {{- section.settings.heading | escape -}}
      </{{ section.settings.heading_tag }}>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="as-seen-in__logos grid grid--2-col-tablet grid--{{ section.settings.columns_desktop }}-col-desktop" role="list">
        {%- for block in section.blocks -%}
          <li class="as-seen-in__logo-item grid__item" {{ block.shopify_attributes }}>
            <div class="as-seen-in__logo-wrap" data-cascade style="--animation-order: {{ forloop.index }};">
              {%- if block.settings.logo != blank -%}
                {{
                  block.settings.logo
                  | image_url: width: 400
                  | image_tag:
                    widths: '150, 200, 300, 400',
                    sizes: '(min-width: 990px) 200px, (min-width: 750px) 150px, 120px',
                    class: 'as-seen-in__logo',
                    loading: 'lazy',
                    alt: block.settings.logo.alt | default: block.settings.label | escape
                }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg as-seen-in__logo-placeholder' }}
              {%- endif -%}
              {%- if block.settings.label != blank -%}
                <span class="visually-hidden">{{ block.settings.label | escape }}</span>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{% style %}
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .section-{{ section.id }} .as-seen-in__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.6rem;
  }

  .section-{{ section.id }} .as-seen-in__heading {
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    text-align: center;
    margin: 0;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .section-{{ section.id }} .as-seen-in__logos {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
    align-items: center;
    justify-items: center;
    row-gap: 1.6rem;
    column-gap: 2rem;
  }

  .section-{{ section.id }} .as-seen-in__logo-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.8rem;
  }

  .section-{{ section.id }} .as-seen-in__logo {
    max-height: {{ section.settings.logo_max_height }}px;
    width: auto;
    object-fit: contain;
    opacity: {{ section.settings.logo_opacity | divided_by: 100.0 }};
  }

  .section-{{ section.id }} .as-seen-in__logo-placeholder {
    max-height: {{ section.settings.logo_max_height }}px;
    width: 150px;
  }

  @media (min-width: 750px) {
    .section-{{ section.id }} .as-seen-in__inner {
      gap: 2rem;
    }

    .section-{{ section.id }} .as-seen-in__logos {
      column-gap: 3.2rem;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .section-{{ section.id }} .as-seen-in__logo-wrap[data-cascade] {
      opacity: 0;
      animation: fadeIn 0.5s ease forwards;
      animation-delay: calc(0.1s * var(--animation-order));
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(0.6rem); }
      to { opacity: 1; transform: translateY(0); }
    }
  }
{% endstyle %}

