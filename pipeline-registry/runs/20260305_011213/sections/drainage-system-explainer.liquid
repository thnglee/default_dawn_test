{%- comment -%}
  Section: drainage-system-explainer
  Type: rich_text
  Generated by: Section Conversion Agent v1.2
  Dawn version: 15.0
{%- endcomment -%}

{{ 'section-rich-text.css' | asset_url | stylesheet_tag }}

<section
  class="section-{{ section.id }} drainage-system-explainer color-{{ section.settings.color_scheme }} gradient"
  id="Section-{{ section.id }}"
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <{{ section.settings.heading_size }} class="drainage-system-explainer__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading | escape }}
      </{{ section.settings.heading_size }}>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <div class="drainage-system-explainer__subheading rte">
        {{ section.settings.subheading }}
      </div>
    {%- endif -%}

    <div class="grid grid--2-col-tablet drainage-system-explainer__grid">
      {%- comment -%} Left column: text content, bullet points, callout {%- endcomment -%}
      <div class="grid__item drainage-system-explainer__text-col">
        {%- if section.settings.body_text != blank -%}
          <div class="drainage-system-explainer__body rte">
            {{ section.settings.body_text }}
          </div>
        {%- endif -%}

        {%- assign bullet_blocks = section.blocks | where: 'type', 'bullet_item' -%}
        {%- if bullet_blocks.size > 0 -%}
          <ul class="drainage-system-explainer__bullets list-unstyled" role="list">
            {%- for block in bullet_blocks -%}
              <li class="drainage-system-explainer__bullet" {{ block.shopify_attributes }}>
                <span class="drainage-system-explainer__bullet-icon" aria-hidden="true">
                  {%- if block.settings.icon_style == 'x_mark' -%}
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <circle cx="10" cy="10" r="10" fill="currentColor" opacity="0.15"/>
                      <path d="M6 6l8 8M14 6l-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                  {%- elsif block.settings.icon_style == 'check' -%}
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <circle cx="10" cy="10" r="10" fill="currentColor" opacity="0.15"/>
                      <path d="M6 10l3 3 5-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  {%- else -%}
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <circle cx="10" cy="10" r="6" fill="currentColor"/>
                    </svg>
                  {%- endif -%}
                </span>
                <span class="drainage-system-explainer__bullet-text">
                  {{ block.settings.text | escape }}
                </span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- assign callout_blocks = section.blocks | where: 'type', 'callout_box' -%}
        {%- for block in callout_blocks -%}
          <div class="drainage-system-explainer__callout color-{{ block.settings.callout_color_scheme }}" {{ block.shopify_attributes }}>
            {%- if block.settings.callout_heading != blank -%}
              <h4 class="drainage-system-explainer__callout-heading h4">
                {{ block.settings.callout_heading | escape }}
              </h4>
            {%- endif -%}
            {%- if block.settings.callout_text != blank -%}
              <div class="drainage-system-explainer__callout-body rte">
                {{ block.settings.callout_text }}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      {%- comment -%} Right column: media / images {%- endcomment -%}
      <div class="grid__item drainage-system-explainer__media-col">
        {%- assign media_blocks = section.blocks | where: 'type', 'media_item' -%}
        {%- if media_blocks.size > 0 -%}
          <div class="drainage-system-explainer__media-stack">
            {%- for block in media_blocks -%}
              <figure class="drainage-system-explainer__media-figure" {{ block.shopify_attributes }}
                data-cascade
                style="--animation-order: {{ forloop.index }};"
              >
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 1500
                    | image_tag:
                      widths: '375, 550, 750, 1100, 1500',
                      sizes: '(min-width: 990px) calc((100vw - 10rem) / 2), (min-width: 750px) calc((100vw - 11.5rem) / 2), calc(100vw - 4rem)',
                      class: 'drainage-system-explainer__image',
                      loading: 'lazy',
                      alt: block.settings.image.alt | escape
                  }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
                {%- if block.settings.caption != blank -%}
                  <figcaption class="drainage-system-explainer__caption">
                    {{ block.settings.caption | escape }}
                  </figcaption>
                {%- endif -%}
              </figure>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% style %}
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .section-{{ section.id }} .drainage-system-explainer__heading {
    text-align: center;
    margin-bottom: 1rem;
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
  }

  .section-{{ section.id }} .drainage-system-explainer__subheading {
    text-align: center;
    margin-bottom: 2.5rem;
    max-width: 72rem;
    margin-inline: auto;
  }

  .section-{{ section.id }} .drainage-system-explainer__grid {
    align-items: start;
    gap: 2rem;
  }

  .section-{{ section.id }} .drainage-system-explainer__body {
    margin-bottom: 1.5rem;
  }

  .section-{{ section.id }} .drainage-system-explainer__bullets {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding: 0;
  }

  .section-{{ section.id }} .drainage-system-explainer__bullet {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    line-height: 1.5;
  }

  .section-{{ section.id }} .drainage-system-explainer__bullet-icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.15em;
    color: rgb(var(--color-foreground));
  }

  .section-{{ section.id }} .drainage-system-explainer__bullet--x_mark .drainage-system-explainer__bullet-icon,
  .section-{{ section.id }} .drainage-system-explainer__bullet-icon svg[viewBox] {
    /* icon color inherits from color scheme */
  }

  .section-{{ section.id }} .drainage-system-explainer__callout {
    border-radius: 0.75rem;
    padding: 1.5rem;
    margin-top: 1rem;
  }

  .section-{{ section.id }} .drainage-system-explainer__callout-heading {
    margin-bottom: 0.5rem;
    font-family: var(--font-heading-family);
  }

  .section-{{ section.id }} .drainage-system-explainer__media-stack {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .section-{{ section.id }} .drainage-system-explainer__media-figure {
    margin: 0;
  }

  .section-{{ section.id }} .drainage-system-explainer__image {
    width: 100%;
    height: auto;
    border-radius: 0.5rem;
    display: block;
  }

  .section-{{ section.id }} .drainage-system-explainer__caption {
    font-size: 0.875rem;
    margin-top: 0.5rem;
    opacity: 0.7;
    text-align: center;
  }

  @media (min-width: 750px) {
    .section-{{ section.id }} .drainage-system-explainer__grid {
      gap: 3rem;
    }
  }

  @media (min-width: 990px) {
    .section-{{ section.id }} .drainage-system-explainer__grid {
      gap: 4rem;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .section-{{ section.id }} [data-cascade] {
      opacity: 0;
      animation: drainageExplainerFadeIn 0.5s ease forwards;
      animation-delay: calc(var(--animation-order, 0) * 0.1s);
    }

    @keyframes drainageExplainerFadeIn {
      from {
        opacity: 0;
        transform: translateY(1rem);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }
{% endstyle %}

