{%- comment -%}
  Section: symptom-cause-table
  Type: rich_text
  Generated by: Section Conversion Agent v1.2
  Dawn version: 15.0
{%- endcomment -%}

{%- style -%}
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .section-{{ section.id }} .symptom-cause-table__heading {
    text-align: center;
    margin-bottom: 1.5rem;
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
  }

  .section-{{ section.id }} .symptom-cause-table__subheading {
    text-align: center;
    margin-bottom: 2.5rem;
    max-width: 60ch;
    margin-inline: auto;
    color: rgba(var(--color-foreground), 0.75);
  }

  .section-{{ section.id }} .symptom-cause-table__table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0 0.6rem;
  }

  .section-{{ section.id }} .symptom-cause-table__table thead th {
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    font-size: 1.1rem;
    text-align: left;
    padding: 0.8rem 1.2rem;
    color: rgb(var(--color-foreground));
    border-bottom: 0.2rem solid rgba(var(--color-foreground), 0.15);
  }

  .section-{{ section.id }} .symptom-cause-table__table thead th:first-child {
    padding-left: 0;
  }

  .section-{{ section.id }} .symptom-cause-table__row td {
    padding: 1rem 1.2rem;
    vertical-align: middle;
    background: rgba(var(--color-foreground), 0.04);
    font-size: 1rem;
    line-height: 1.5;
  }

  .section-{{ section.id }} .symptom-cause-table__row td:first-child {
    border-radius: 0.8rem 0 0 0.8rem;
  }

  .section-{{ section.id }} .symptom-cause-table__row td:last-child {
    border-radius: 0 0.8rem 0.8rem 0;
  }

  .section-{{ section.id }} .symptom-cause-table__icon-cell {
    width: 3.6rem;
    text-align: center;
    padding-right: 0;
  }

  .section-{{ section.id }} .symptom-cause-table__icon-cell img {
    width: 2.8rem;
    height: 2.8rem;
    object-fit: contain;
    display: block;
    margin: 0 auto;
  }

  .section-{{ section.id }} .symptom-cause-table__symptom {
    font-weight: 600;
    color: rgb(var(--color-foreground));
  }

  .section-{{ section.id }} .symptom-cause-table__cause {
    color: rgba(var(--color-foreground), 0.85);
  }

  .section-{{ section.id }} .symptom-cause-table__arrow-cell {
    width: 2.4rem;
    text-align: center;
    padding: 1rem 0;
  }

  .section-{{ section.id }} .symptom-cause-table__arrow-cell svg {
    width: 1.4rem;
    height: 1.4rem;
    color: rgba(var(--color-foreground), 0.5);
  }

  @media (max-width: 749px) {
    .section-{{ section.id }} .symptom-cause-table__table,
    .section-{{ section.id }} .symptom-cause-table__table thead,
    .section-{{ section.id }} .symptom-cause-table__table tbody,
    .section-{{ section.id }} .symptom-cause-table__table tr,
    .section-{{ section.id }} .symptom-cause-table__table th,
    .section-{{ section.id }} .symptom-cause-table__table td {
      display: block;
    }

    .section-{{ section.id }} .symptom-cause-table__table thead {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
    }

    .section-{{ section.id }} .symptom-cause-table__row {
      margin-bottom: 0.8rem;
    }

    .section-{{ section.id }} .symptom-cause-table__row td {
      border-radius: 0;
      padding: 0.6rem 1rem;
    }

    .section-{{ section.id }} .symptom-cause-table__row td:first-child {
      border-radius: 0.8rem 0.8rem 0 0;
      padding-top: 1rem;
    }

    .section-{{ section.id }} .symptom-cause-table__row td:last-child {
      border-radius: 0 0 0.8rem 0.8rem;
      padding-bottom: 1rem;
    }

    .section-{{ section.id }} .symptom-cause-table__icon-cell {
      width: 100%;
      text-align: left;
      padding-left: 1rem;
    }

    .section-{{ section.id }} .symptom-cause-table__icon-cell img {
      margin: 0;
    }

    .section-{{ section.id }} .symptom-cause-table__arrow-cell {
      width: 100%;
      text-align: left;
      padding-left: 1rem;
    }

    .section-{{ section.id }} .symptom-cause-table__arrow-cell svg {
      transform: rotate(90deg);
    }

    .section-{{ section.id }} .symptom-cause-table__cause::before,
    .section-{{ section.id }} .symptom-cause-table__symptom::before {
      display: block;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 0.2rem;
      opacity: 0.6;
      font-weight: 400;
    }

    .section-{{ section.id }} .symptom-cause-table__symptom::before {
      content: attr(data-label-symptom);
    }

    .section-{{ section.id }} .symptom-cause-table__cause::before {
      content: attr(data-label-cause);
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <{{ section.settings.heading_size }} class="symptom-cause-table__heading">
        {{ section.settings.heading | escape }}
      </{{ section.settings.heading_size }}>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="symptom-cause-table__subheading">
        {{ section.settings.subheading | escape }}
      </p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <table class="symptom-cause-table__table" role="table">
        <thead>
          <tr>
            <th scope="col" class="symptom-cause-table__icon-cell">
              <span class="visually-hidden">{{ section.settings.icon_column_label | escape }}</span>
            </th>
            <th scope="col">{{ section.settings.symptom_column_label | escape }}</th>
            <th scope="col" class="symptom-cause-table__arrow-cell">
              <span class="visually-hidden">{{ 'accessibility.arrow' | t | default: 'leads to' }}</span>
            </th>
            <th scope="col">{{ section.settings.cause_column_label | escape }}</th>
          </tr>
        </thead>
        <tbody>
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'table_row' -%}
                <tr class="symptom-cause-table__row" {{ block.shopify_attributes }}>
                  <td class="symptom-cause-table__icon-cell">
                    {%- if block.settings.icon != blank -%}
                      {{
                        block.settings.icon
                        | image_url: width: 112
                        | image_tag:
                          widths: '56, 80, 112',
                          loading: 'lazy',
                          alt: block.settings.symptom_text | escape
                      }}
                    {%- endif -%}
                  </td>
                  <td
                    class="symptom-cause-table__symptom"
                    data-label-symptom="{{ section.settings.symptom_column_label | escape }}"
                  >
                    {{ block.settings.symptom_text | escape }}
                  </td>
                  <td class="symptom-cause-table__arrow-cell" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M5 12h14"></path>
                      <path d="m12 5 7 7-7 7"></path>
                    </svg>
                  </td>
                  <td
                    class="symptom-cause-table__cause"
                    data-label-cause="{{ section.settings.cause_column_label | escape }}"
                  >
                    {{ block.settings.cause_text | escape }}
                  </td>
                </tr>
            {%- endcase -%}
          {%- endfor -%}
        </tbody>
      </table>
    {%- endif -%}
  </div>
</div>

