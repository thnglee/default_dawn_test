{%- comment -%}
  Section: synergistic-effect
  Type: rich_text
  Generated by: Section Conversion Agent v1.2
  Dawn version: 15.0
{%- endcomment -%}

{{ 'section-rich-text.css' | asset_url | stylesheet_tag }}

<section
  class="section synergistic-effect color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}"
  aria-label="{{ section.settings.heading | escape }}"
>
  <div class="page-width">
    <div class="synergistic-effect__inner">
      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_size }} class="synergistic-effect__heading">
          {{ section.settings.heading | escape }}
        </{{ section.settings.heading_size }}>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <div class="synergistic-effect__subheading rte">
          {{ section.settings.subheading }}
        </div>
      {%- endif -%}

      {%- if section.settings.callout_text != blank -%}
        <div class="synergistic-effect__callout">
          <div class="synergistic-effect__callout-inner rte">
            {{ section.settings.callout_text }}
          </div>
        </div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="synergistic-effect__benefits list-unstyled" role="list">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'benefit_item' -%}
                <li class="synergistic-effect__benefit" {{ block.shopify_attributes }}>
                  <div class="synergistic-effect__benefit-icon" aria-hidden="true">
                    {%- if block.settings.custom_icon != blank -%}
                      {{
                        block.settings.custom_icon
                        | image_url: width: 80
                        | image_tag:
                          widths: '40, 60, 80',
                          loading: 'lazy',
                          alt: ''
                      }}
                    {%- else -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" fill="currentColor"/>
                      </svg>
                    {%- endif -%}
                  </div>
                  <div class="synergistic-effect__benefit-text">
                    <p>{{ block.settings.text | escape }}</p>
                  </div>
                </li>
            {%- endcase -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.restoration_text != blank -%}
        <div class="synergistic-effect__restoration rte">
          {{ section.settings.restoration_text }}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% style %}
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .section-{{ section.id }} .synergistic-effect__inner {
    max-width: 72rem;
    margin: 0 auto;
    text-align: center;
  }

  .section-{{ section.id }} .synergistic-effect__heading {
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    margin: 0 0 1.6rem;
    color: rgba(var(--color-foreground), 1);
  }

  .section-{{ section.id }} .synergistic-effect__subheading {
    margin: 0 auto 2.4rem;
    max-width: 60rem;
    color: rgba(var(--color-foreground), 0.75);
  }

  .section-{{ section.id }} .synergistic-effect__callout {
    border: 0.2rem solid rgba(var(--color-foreground), 0.3);
    border-radius: 1.2rem;
    padding: 2rem 2.4rem;
    margin: 0 auto 3.2rem;
    max-width: 60rem;
    background: transparent;
  }

  .section-{{ section.id }} .synergistic-effect__callout-inner p {
    margin: 0;
  }

  .section-{{ section.id }} .synergistic-effect__benefits {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    margin: 0 auto 3.2rem;
    max-width: 56rem;
    padding: 0;
  }

  .section-{{ section.id }} .synergistic-effect__benefit {
    display: flex;
    align-items: flex-start;
    gap: 1.2rem;
    text-align: left;
  }

  .section-{{ section.id }} .synergistic-effect__benefit-icon {
    flex-shrink: 0;
    width: 3.2rem;
    height: 3.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(var(--color-foreground), 0.7);
  }

  .section-{{ section.id }} .synergistic-effect__benefit-icon img,
  .section-{{ section.id }} .synergistic-effect__benefit-icon svg {
    width: 2.4rem;
    height: 2.4rem;
    object-fit: contain;
  }

  .section-{{ section.id }} .synergistic-effect__benefit-text p {
    margin: 0;
    line-height: 1.6;
  }

  .section-{{ section.id }} .synergistic-effect__restoration {
    margin: 0 auto;
    max-width: 60rem;
    font-style: italic;
    color: rgba(var(--color-foreground), 0.75);
  }

  @media (min-width: 750px) {
    .section-{{ section.id }} .synergistic-effect__benefits {
      gap: 2rem;
    }

    .section-{{ section.id }} .synergistic-effect__callout {
      padding: 2.4rem 3.2rem;
    }

    .section-{{ section.id }} .synergistic-effect__benefit-icon {
      width: 4rem;
      height: 4rem;
    }

    .section-{{ section.id }} .synergistic-effect__benefit-icon img,
    .section-{{ section.id }} .synergistic-effect__benefit-icon svg {
      width: 3.2rem;
      height: 3.2rem;
    }
  }
{% endstyle %}

