  "_allowlist": {
    "description": "These are Dawn native class patterns. If a section DOM snippet matches ONLY these, do NOT classify it as an app.",
    "dawn_native_classes": [
      "product", "product__media", "product__info", "product-form",
      "card-wrapper", "card", "card__media", "card__content",
      "price", "price__regular", "price--on-sale",
      "button", "button--primary", "button--secondary", "button--full-width",
      "page-width", "grid", "grid__item",
      "section", "shopify-section",
      "color-scheme", "gradient",
      "facets", "facet-filters-form",
      "cart-drawer", "cart-notification",
      "header", "header__inner",
