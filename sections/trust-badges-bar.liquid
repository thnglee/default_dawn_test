{%- comment -%}
  Section: trust-badges-bar
  Type: trust_badges
  Generated by: Section Conversion Agent v1.2
  Dawn version: 15.0
{%- endcomment -%}

{{ 'section-trust-badges-bar.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign color_scheme = section.settings.color_scheme
-%}

<div class="section-{{ section.id }} trust-badges-bar color-{{ color_scheme }} gradient">
  <div class="trust-badges-bar__inner page-width">
    <ul class="trust-badges-bar__list grid grid--2-col-tablet grid--4-col-desktop" role="list">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'badge_item' -%}
            <li class="trust-badges-bar__item grid__item" {{ block.shopify_attributes }}>
              <div class="trust-badges-bar__badge" data-cascade style="--animation-order: {{ forloop.index }};">
                {%- if block.settings.icon == 'custom' and block.settings.custom_icon != blank -%}
                  <div class="trust-badges-bar__icon-wrapper">
                    {{
                      block.settings.custom_icon
                      | image_url: width: 96
                      | image_tag:
                        widths: '48, 64, 96',
                        sizes: '48px',
                        loading: 'lazy',
                        class: 'trust-badges-bar__icon',
                        alt: block.settings.custom_icon.alt | default: block.settings.heading | escape
                    }}
                  </div>
                {%- else -%}
                  <div class="trust-badges-bar__icon-wrapper trust-badges-bar__icon-wrapper--svg">
                    {%- case block.settings.icon -%}
                      {%- when 'shipping' -%}
                        <svg class="trust-badges-bar__icon-svg" width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                          <path d="M6 12h18v14H6z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                          <path d="M24 18h5l4 4v4h-9V18z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                          <circle cx="11" cy="28" r="2.5" stroke="currentColor" stroke-width="2"/>
                          <circle cx="29" cy="28" r="2.5" stroke="currentColor" stroke-width="2"/>
                        </svg>
                      {%- when 'leaf' -%}
                        <svg class="trust-badges-bar__icon-svg" width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                          <path d="M20 34S8 26 8 16C8 10 13 6 20 6s12 4 12 10c0 10-12 18-12 18z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                          <path d="M14 22c2-4 6-8 12-10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      {%- when 'ingredients' -%}
                        <svg class="trust-badges-bar__icon-svg" width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                          <circle cx="20" cy="20" r="13" stroke="currentColor" stroke-width="2"/>
                          <path d="M14 20l4 4 8-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      {%- when 'guarantee' -%}
                        <svg class="trust-badges-bar__icon-svg" width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                          <path d="M20 6l3.09 6.26L30 13.27l-5 4.87 1.18 6.88L20 21.77l-6.18 3.25L15 18.14l-5-4.87 6.91-1.01L20 6z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      {%- else -%}
                        <svg class="trust-badges-bar__icon-svg" width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                          <circle cx="20" cy="20" r="13" stroke="currentColor" stroke-width="2"/>
                          <path d="M14 20l4 4 8-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    {%- endcase -%}
                  </div>
                {%- endif -%}

                {%- if block.settings.heading != blank -%}
                  <p class="trust-badges-bar__heading">
                    {{ block.settings.heading | escape }}
                  </p>
                {%- endif -%}

                {%- if block.settings.subtext != blank -%}
                  <p class="trust-badges-bar__subtext">
                    {{ block.settings.subtext | escape }}
                  </p>
                {%- endif -%}
              </div>
            </li>
        {%- endcase -%}
      {%- endfor -%}
    </ul>
  </div>
</div>

{% style %}
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .section-{{ section.id }} .trust-badges-bar__inner {
    max-width: 120rem;
  }

  .section-{{ section.id }} .trust-badges-bar__list {
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1.5rem;
    align-items: start;
  }

  .section-{{ section.id }} .trust-badges-bar__badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.8rem;
  }

  .section-{{ section.id }} .trust-badges-bar__icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4.8rem;
    height: 4.8rem;
    flex-shrink: 0;
  }

  .section-{{ section.id }} .trust-badges-bar__icon {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .section-{{ section.id }} .trust-badges-bar__icon-svg {
    width: 4rem;
    height: 4rem;
    color: rgba(var(--color-foreground), 1);
  }

  .section-{{ section.id }} .trust-badges-bar__heading {
    margin: 0;
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    font-size: 1.4rem;
    line-height: 1.3;
    letter-spacing: 0.04em;
    color: rgba(var(--color-foreground), 1);
  }

  .section-{{ section.id }} .trust-badges-bar__subtext {
    margin: 0;
    font-family: var(--font-body-family);
    font-size: 1.2rem;
    line-height: 1.4;
    color: rgba(var(--color-foreground), 0.75);
  }

  @media (min-width: 750px) {
    .section-{{ section.id }} .trust-badges-bar__badge {
      flex-direction: row;
      text-align: left;
      gap: 1.2rem;
    }

    .section-{{ section.id }} .trust-badges-bar__heading {
      font-size: 1.5rem;
    }
  }

  @media (min-width: 990px) {
    .section-{{ section.id }} .trust-badges-bar__badge {
      justify-content: center;
    }

    .section-{{ section.id }} .trust-badges-bar__heading {
      font-size: 1.6rem;
    }
  }
{% endstyle %}

