{%- comment -%}
  Section: why-nothing-worked
  Type: rich_text
  Generated by: Section Conversion Agent v1.2
  Dawn version: 15.0
{%- endcomment -%}

{{ 'section-why-nothing-worked.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign color_scheme = section.settings.color_scheme
-%}

<div class="section-{{ section.id }} why-nothing-worked color-{{ color_scheme }} gradient">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="why-nothing-worked__header center">
        <{{ section.settings.heading_size }} class="why-nothing-worked__heading">
          {{ section.settings.heading | escape }}
        </{{ section.settings.heading_size }}>
        {%- if section.settings.subheading != blank -%}
          <div class="why-nothing-worked__subheading rte">
            {{ section.settings.subheading }}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- assign failure_blocks = section.blocks | where: 'type', 'failure_card' -%}
    {%- if failure_blocks.size > 0 -%}
      <ul class="why-nothing-worked__grid grid grid--3-col-desktop grid--1-col-tablet-down" role="list">
        {%- for block in failure_blocks -%}
          <li class="grid__item" {{ block.shopify_attributes }}>
            <div class="why-nothing-worked__card" data-cascade style="--animation-order: {{ forloop.index }};">
              <div class="why-nothing-worked__image-wrapper">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 800
                    | image_tag:
                      widths: '275, 375, 550, 800',
                      sizes: '(min-width: 990px) calc((100vw - 10rem) / 3), (min-width: 750px) calc((100vw - 10rem) / 2), calc(100vw - 4rem)',
                      loading: 'lazy',
                      class: 'why-nothing-worked__image',
                      alt: block.settings.image.alt | escape
                  }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
                {%- if block.settings.show_crossout -%}
                  <span class="why-nothing-worked__crossout" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="6" stroke-linecap="round">
                      <line x1="15" y1="15" x2="85" y2="85"/>
                      <line x1="85" y1="15" x2="15" y2="85"/>
                    </svg>
                  </span>
                {%- endif -%}
              </div>
              {%- if block.settings.heading != blank -%}
                <h3 class="why-nothing-worked__card-heading h4">
                  {{ block.settings.heading | escape }}
                </h3>
              {%- endif -%}
              {%- if block.settings.reason != blank -%}
                <div class="why-nothing-worked__card-reason rte">
                  {{ block.settings.reason }}
                </div>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- assign callout_block = section.blocks | where: 'type', 'callout' | first -%}
    {%- if callout_block -%}
      <div class="why-nothing-worked__callout" {{ callout_block.shopify_attributes }}>
        {%- if callout_block.settings.heading != blank -%}
          <h3 class="why-nothing-worked__callout-heading h3">
            {{ callout_block.settings.heading | escape }}
          </h3>
        {%- endif -%}
        {%- if callout_block.settings.content != blank -%}
          <div class="why-nothing-worked__callout-content rte">
            {{ callout_block.settings.content }}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <div class="why-nothing-worked__cta center">
        <a
          {% if section.settings.button_url != blank %}href="{{ section.settings.button_url }}"{% endif %}
          class="button button--primary"
        >
          {{ section.settings.button_label | escape }}
        </a>
      </div>
    {%- endif -%}

    {%- assign guarantee_block = section.blocks | where: 'type', 'guarantee_badge' | first -%}
    {%- if guarantee_block -%}
      <div class="why-nothing-worked__guarantee center" {{ guarantee_block.shopify_attributes }}>
        {%- if guarantee_block.settings.image != blank -%}
          <div class="why-nothing-worked__guarantee-icon">
            {{
              guarantee_block.settings.image
              | image_url: width: 120
              | image_tag:
                widths: '60, 90, 120',
                loading: 'lazy',
                class: 'why-nothing-worked__guarantee-image',
                alt: guarantee_block.settings.image.alt | escape
            }}
          </div>
        {%- endif -%}
        {%- if guarantee_block.settings.text != blank -%}
          <p class="why-nothing-worked__guarantee-text">
            {{ guarantee_block.settings.text | escape }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% style %}
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .section-{{ section.id }} .why-nothing-worked__header {
    margin-bottom: 4rem;
  }

  .section-{{ section.id }} .why-nothing-worked__heading {
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    margin: 0 0 1rem;
  }

  .section-{{ section.id }} .why-nothing-worked__subheading {
    max-width: 72rem;
    margin: 0 auto;
  }

  .section-{{ section.id }} .why-nothing-worked__grid {
    list-style: none;
    padding: 0;
    margin: 0 0 4rem;
    gap: 2rem;
  }

  .section-{{ section.id }} .why-nothing-worked__card {
    text-align: center;
    padding: 2rem 1.5rem;
    border-radius: var(--border-radius, 0.8rem);
    background: rgba(var(--color-foreground), 0.04);
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .section-{{ section.id }} .why-nothing-worked__image-wrapper {
    position: relative;
    display: inline-block;
    margin-bottom: 1.5rem;
    width: 100%;
    max-width: 20rem;
  }

  .section-{{ section.id }} .why-nothing-worked__image {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--border-radius, 0.8rem);
  }

  .section-{{ section.id }} .why-nothing-worked__crossout {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    color: rgba(var(--color-foreground), 0.7);
  }

  .section-{{ section.id }} .why-nothing-worked__crossout svg {
    width: 60%;
    height: 60%;
  }

  .section-{{ section.id }} .why-nothing-worked__card-heading {
    margin: 0 0 0.8rem;
  }

  .section-{{ section.id }} .why-nothing-worked__card-reason {
    color: rgba(var(--color-foreground), 0.75);
    font-size: 1.4rem;
    line-height: 1.6;
  }

  .section-{{ section.id }} .why-nothing-worked__callout {
    background: rgba(var(--color-foreground), 0.06);
    border-radius: var(--border-radius, 0.8rem);
    padding: 3rem 2.5rem;
    margin: 0 auto 3rem;
    max-width: 72rem;
    text-align: center;
  }

  .section-{{ section.id }} .why-nothing-worked__callout-heading {
    margin: 0 0 1.2rem;
  }

  .section-{{ section.id }} .why-nothing-worked__callout-content {
    color: rgba(var(--color-foreground), 0.8);
  }

  .section-{{ section.id }} .why-nothing-worked__cta {
    margin-bottom: 2rem;
  }

  .section-{{ section.id }} .why-nothing-worked__guarantee {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
  }

  .section-{{ section.id }} .why-nothing-worked__guarantee-icon {
    width: 6rem;
    height: auto;
  }

  .section-{{ section.id }} .why-nothing-worked__guarantee-image {
    width: 100%;
    height: auto;
  }

  .section-{{ section.id }} .why-nothing-worked__guarantee-text {
    font-size: 1.3rem;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .section-{{ section.id }} .why-nothing-worked__card {
      opacity: 0;
      animation: whyNothingWorkedFadeIn 0.4s ease forwards;
      animation-delay: calc(var(--animation-order, 0) * 0.1s);
    }

    @keyframes whyNothingWorkedFadeIn {
      from { opacity: 0; transform: translateY(1rem); }
      to { opacity: 1; transform: translateY(0); }
    }
  }
{% endstyle %}

