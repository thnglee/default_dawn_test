{%- comment -%}
  Section: symptoms-explainer
  Type: rich_text
  Generated by: Section Conversion Agent v1.2
  Dawn version: 15.0
{%- endcomment -%}

{{ 'section-symptoms-explainer.css' | asset_url | stylesheet_tag }}

<div class="section-{{ section.id }} symptoms-explainer color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width symptoms-explainer__inner">

    {%- if section.settings.heading != blank -%}
      <div class="symptoms-explainer__header center">
        {%- if section.settings.subheading != blank -%}
          <p class="symptoms-explainer__subheading caption-with-letter-spacing">
            {{ section.settings.subheading | escape }}
          </p>
        {%- endif -%}
        <{{ section.settings.heading_size }} class="symptoms-explainer__heading">
          {{ section.settings.heading | escape }}
        </{{ section.settings.heading_size }}>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      {%- assign symptom_blocks = section.blocks | where: 'type', 'symptom_card' -%}
      {%- if symptom_blocks.size > 0 -%}
        <ul class="symptoms-explainer__grid grid grid--2-col-tablet grid--{{ section.settings.columns_desktop }}-col-desktop" role="list">
          {%- for block in symptom_blocks -%}
            <li class="grid__item symptoms-explainer__card" {{ block.shopify_attributes }}>
              <div class="symptoms-explainer__card-inner" data-cascade style="--animation-order: {{ forloop.index }};">
                <div class="symptoms-explainer__card-media media">
                  {%- if block.settings.image != blank -%}
                    {{
                      block.settings.image
                      | image_url: width: 600
                      | image_tag:
                        widths: '200, 300, 400, 600',
                        sizes: '(min-width: 990px) 20vw, (min-width: 750px) 33vw, 45vw',
                        loading: 'lazy',
                        class: 'symptoms-explainer__card-image',
                        alt: block.settings.image.alt | default: block.settings.title | escape
                    }}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </div>
                {%- if block.settings.title != blank -%}
                  <p class="symptoms-explainer__card-title h4">
                    {{ block.settings.title | escape }}
                  </p>
                {%- endif -%}
              </div>
            </li>
          {%- endfor -%}
        </ul>

        {%- if section.settings.show_arrow -%}
          <div class="symptoms-explainer__arrow center" aria-hidden="true">
            <svg width="40" height="48" viewBox="0 0 40 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 0 L20 40 M6 28 L20 42 L34 28" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        {%- endif -%}
      {%- endif -%}

      {%- assign callout_blocks = section.blocks | where: 'type', 'callout_box' -%}
      {%- for block in callout_blocks -%}
        <div
          class="symptoms-explainer__callout color-{{ block.settings.color_scheme }} gradient"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.callout_heading != blank -%}
            <h3 class="symptoms-explainer__callout-heading h3">
              {{ block.settings.callout_heading | escape }}
            </h3>
          {%- endif -%}
          {%- if block.settings.callout_text != blank -%}
            <div class="symptoms-explainer__callout-text rte">
              {{ block.settings.callout_text }}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- endif -%}

  </div>
</div>

{% style %}
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .section-{{ section.id }} .symptoms-explainer__header {
    margin-bottom: 3.2rem;
  }

  .section-{{ section.id }} .symptoms-explainer__subheading {
    margin-bottom: 0.8rem;
    color: rgba(var(--color-foreground), 0.65);
  }

  .section-{{ section.id }} .symptoms-explainer__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    gap: 1.6rem;
    justify-items: center;
  }

  .section-{{ section.id }} .symptoms-explainer__card-inner {
    text-align: center;
  }

  .section-{{ section.id }} .symptoms-explainer__card-media {
    overflow: hidden;
    border-radius: var(--media-radius, 0.8rem);
    margin-bottom: 1.2rem;
  }

  .section-{{ section.id }} .symptoms-explainer__card-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .section-{{ section.id }} .symptoms-explainer__card-title {
    margin: 0;
  }

  .section-{{ section.id }} .symptoms-explainer__arrow {
    margin: 2.4rem auto;
    color: rgba(var(--color-foreground), 0.55);
  }

  .section-{{ section.id }} .symptoms-explainer__callout {
    border-radius: var(--media-radius, 0.8rem);
    padding: 2.4rem 3.2rem;
    text-align: center;
    max-width: 72rem;
    margin: 0 auto;
  }

  .section-{{ section.id }} .symptoms-explainer__callout-heading {
    margin: 0 0 1.2rem;
  }

  .section-{{ section.id }} .symptoms-explainer__callout-text {
    margin: 0;
  }

  @media (min-width: 750px) {
    .section-{{ section.id }} .symptoms-explainer__header {
      margin-bottom: 4rem;
    }

    .section-{{ section.id }} .symptoms-explainer__callout {
      padding: 3.2rem 4.8rem;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .section-{{ section.id }} .symptoms-explainer__card-inner[data-cascade] {
      opacity: 0;
      animation: symptomsFadeIn 0.5s ease forwards;
      animation-delay: calc(var(--animation-order) * 0.1s);
    }

    @keyframes symptomsFadeIn {
      from {
        opacity: 0;
        transform: translateY(1rem);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }
{% endstyle %}

